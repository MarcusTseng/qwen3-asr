# ── CrispASR (Vulkan/GGUF) backend ──────────────────────────────────────────
# Path to the crispasr binary.  Required for the crisp backend.
QWEN3_ASR_CRISP_BIN=/home/marcus/.openclaw/tools/qwen3-asr-crisp/CrispASR/build-vulkan/bin/crispasr
# Path to the GGUF model file.
QWEN3_ASR_CRISP_MODEL=/home/marcus/.openclaw/tools/qwen3-asr-crisp/models/qwen3-asr-1.7b-q8_0.gguf

# ── PyTorch (transformers) backend ───────────────────────────────────────────
# Path to the Python venv created by setup/setup_venv.sh.
# Defaults to $REPO_DIR/venv — only set this if you use a custom location.
# QWEN3_ASR_VENV=/path/to/venv

# ── Whisper fallback ─────────────────────────────────────────────────────────
# OpenAI-compatible whisper-server endpoint.  Defaults shown below.
WHISPER_SERVER_URL=http://localhost:8082/v1/audio/transcriptions

# ── Shared options ───────────────────────────────────────────────────────────
# Language hint passed to all backends that accept it.
# Leave unset for automatic language detection.
# QWEN3_ASR_LANGUAGE=zh

# ── CrispASR tuning (optional) ───────────────────────────────────────────────
# QWEN3_ASR_GPU_BACKEND=vulkan
# QWEN3_ASR_DEVICE=0
# QWEN3_ASR_THREADS=4
# QWEN3_ASR_BEST_OF=2
# QWEN3_ASR_BEAM_SIZE=2
# QWEN3_ASR_MAX_NEW_TOKENS=384
# QWEN3_ASR_TRADITIONAL=1   # 1 = convert Simplified → Traditional Chinese
